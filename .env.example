# Server
PORT=3001
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nazr
DB_USERNAME=root
DB_PASSWORD=change_me

# synchronize فقط در development مجاز است (در production باید false باشد)
DB_SYNCHRONIZE=true
DB_LOGGING=false

# JWT / Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d
OTP_EXPIRES_IN=2m
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
ACCESS_TOKEN_COOKIE_NAME=accessToken
REFRESH_TOKEN_COOKIE_NAME=refreshToken
AUTH_COOKIE_HTTP_ONLY=true
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_PATH=/

# ZarinPal
# فعلا غیرفعال - پرداخت فقط کارت به کارت است (پایین تر را ببینید)
PAYMENT_GATEWAY_ENABLED=false
ZARINPAL_MERCHANT_ID=your-zarinpal-merchant-id
ZARINPAL_SANDBOX=true
PAYMENT_CALLBACK_BASE_URL=http://localhost:3001/api

# Mail (SMTP)
# اختیاری - اگر SMTP_HOST خالی بماند، ایمیل های بازیابی رمز/تایید ایمیل فقط در لاگ سرور چاپ می شوند
# و واقعا ارسال نمی شوند (مناسب توسعه لوکال بدون نیاز به SMTP واقعی).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@roohbakhsh.ac

# آدرس فرانت - برای ساخت لینک های reset-password / verify-email داخل ایمیل
FRONTEND_URL=http://localhost:3000

# پرداخت کارت به کارت
# اطلاعات حساب مقصد آکادمی - به کاربر نمایش داده می شود تا کارت به کارت کند
PAYMENT_DESTINATION_CARD_NUMBER=6037-XXXX-XXXX-XXXX
PAYMENT_DESTINATION_ACCOUNT_HOLDER=آکادمی بین‌المللی اسلامی روح‌بخش
PAYMENT_DESTINATION_BANK_NAME=بانک ملی

# آپلود رسید پرداخت روی FTP
FTP_HOST=ftp.example.com
FTP_PORT=21
FTP_USER=change_me
FTP_PASSWORD=change_me
FTP_UPLOAD_DIR=/receipts
FTP_PUBLIC_BASE_URL=https://cdn.roohbakhsh.ac
FTP_SECURE=false
