# Server
PORT=3001
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001
MEDIA_STORAGE=local
UPLOAD_DIR=uploads
MEDIA_PUBLIC_BASE_URL=http://localhost:3001

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nazr
DB_USERNAME=root
DB_PASSWORD=change_me

# synchronize فقط در development مجاز است (در production باید false باشد)
DB_SYNCHRONIZE=true
DB_LOGGING=false

# JWT / Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d
OTP_EXPIRES_IN=2m
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
ACCESS_TOKEN_COOKIE_NAME=accessToken
REFRESH_TOKEN_COOKIE_NAME=refreshToken
AUTH_COOKIE_HTTP_ONLY=true
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_PATH=/

# Initial admin (used only to create/promote the first administrator)
ADMIN_BOOTSTRAP_NAME=مدیر سامانه
ADMIN_BOOTSTRAP_MOBILE=09120000000
ADMIN_BOOTSTRAP_PASSWORD=change_me_admin_password

# SMS — فراز اس‌ام‌اس (https://iranpayamak.com)
FARAZ_SMS_API_KEY=your-faraz-sms-api-key
FARAZ_SMS_ORIGINATOR=90008361

# ZarinPal
PAYMENT_GATEWAY_ENABLED=false
ZARINPAL_MERCHANT_ID=your-zarinpal-merchant-id
ZARINPAL_SANDBOX=true
API_PUBLIC_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Eitaa
NEXT_PUBLIC_EITAA_RECEIPT_URL=https://eitaa.com/nazr_emam

# Mail (SMTP)
# اختیاری - اگر SMTP_HOST خالی بماند، ایمیل های بازیابی رمز/تایید ایمیل فقط در لاگ سرور چاپ می شوند
# و واقعا ارسال نمی شوند (مناسب توسعه لوکال بدون نیاز به SMTP واقعی).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@roohbakhsh.ac

# پرداخت کارت به کارت
# اطلاعات حساب مقصد آکادمی - به کاربر نمایش داده می شود تا کارت به کارت کند
PAYMENT_DESTINATION_CARD_NUMBER=6037-XXXX-XXXX-XXXX
PAYMENT_DESTINATION_ACCOUNT_HOLDER=آکادمی بین‌المللی اسلامی روح‌بخش
PAYMENT_DESTINATION_BANK_NAME=بانک ملی

# آپلود فایل روی FTP
FTP_HOST=ftp.example.com
FTP_PORT=21
FTP_USER=change_me
FTP_USERNAME=change_me
FTP_PASSWORD=change_me
FTP_UPLOAD_DIR=/receipts
FTP_PUBLIC_BASE_URL=https://cdn.roohbakhsh.ac
FTP_SECURE=false
MEDIA_FTP_UPLOAD_DIR=/gallery
MEDIA_FTP_PUBLIC_BASE_URL=https://cdn.roohbakhsh.ac/gallery
